@page
@model LoginModel

@{
    ViewData["Title"] = "Log In";
}

<div class="container py-5">

    <div class="row justify-content-center">

        <div class="col-lg-5">

            <!-- Back to Home Button -->
            <div class="mb-3">
                <a asp-controller="Home" asp-action="Index"
                   style="display: inline-flex; align-items: center; gap: 6px; background: white; border: 2px solid #2D2D2D; border-radius: 999px; padding: 8px 20px; font-weight: 800; font-size: 0.9rem; box-shadow: 3px 3px 0px #2D2D2D; text-decoration: none; color: #2D2D2D;">
                    ← Back to Home
                </a>
            </div>

            <div class="hatian-card">

                <div class="text-center mb-4">

                    <img src="~/images/HatianLogo.png"
                         alt="Hatian"
                         style="height:120px;" />

                    <h2 class="fw-bold mt-3">
                        Welcome Back 👋
                    </h2>

                    <p class="text-muted">
                        Log in and continue splitting expenses with your barkada.
                    </p>

                </div>

                <form method="post">

                    <div asp-validation-summary="ModelOnly"
                         class="text-danger mb-3">
                    </div>

                    <div class="mb-3">

                        <label asp-for="Input.Email"
                               class="form-label fw-semibold">
                            Email
                        </label>

                        <input asp-for="Input.Email"
                               class="form-control hatian-input" />

                        <span asp-validation-for="Input.Email"
                              class="text-danger">
                        </span>

                    </div>

                    <div class="mb-3">

                        <label asp-for="Input.Password"
                               class="form-label fw-semibold">
                            Password
                        </label>

                        <input asp-for="Input.Password"
                               class="form-control hatian-input" />

                        <span asp-validation-for="Input.Password"
                              class="text-danger">
                        </span>

                    </div>

                    <div class="form-check mb-4">

                        <input asp-for="Input.RememberMe"
                               class="form-check-input" />

                        <label asp-for="Input.RememberMe"
                               class="form-check-label">
                            Remember Me
                        </label>

                    </div>

                    <button type="submit"
                            class="btn-step">
                        Log In
                    </button>

                    <div class="text-center mt-4">

                        <a asp-page="./Register"
                           class="text-decoration-none fw-bold">
                            Don't have an account?
                            Register
                        </a>

                    </div>

                </form>

            </div>

        </div>

    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}