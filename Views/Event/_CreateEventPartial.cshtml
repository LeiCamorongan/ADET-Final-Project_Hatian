@model Hatian.Models.ViewModels.CreateEventViewModel

<h2 class="fw-bold mb-4">Create Event</h2>

<form asp-controller="Event" asp-action="Create" method="post">

    <div class="mb-3">
        <label class="form-label fw-bold">Event Title</label>
        <input asp-for="Title" class="form-control hatian-input" required />
    </div>

    <div class="mb-3">
        <label class="form-label fw-bold">Description</label>
        <textarea asp-for="Description" class="form-control hatian-input"></textarea>
    </div>

    <div class="mb-4">
        <label class="form-label fw-bold">Date</label>
        <input asp-for="Date" type="date" class="form-control hatian-input" min="@DateTime.Today.ToString("yyyy-MM-dd")" required />
    </div>

    <!-- Your Contribution -->
    <div class="info-card" style="margin-bottom: 1rem; box-shadow: none;">
        <div style="font-weight: 800; font-size: 1.05rem; color: #2D2D2D;">Your Contribution</div>
        <div style="font-size: 0.8rem; color: #888; margin-bottom: 1rem;">What are you bringing to this event?</div>

        <div class="d-flex align-items-center gap-2">
            <div class="avatar-circle lg" style="background: var(--pink);">YOU</div>
            <div style="flex: 1;">
                <input asp-for="OrganizerNameAsParticipant"
                       class="form-control hatian-input mb-2"
                       placeholder="Your Name" required />
                <input asp-for="OrganizerContribution"
                       class="form-control hatian-input"
                       placeholder="e.g. desserts, drinks, plates..." required/>
            </div>
        </div>
    </div>

    <!-- Invite Friends -->
    <div class="info-card" style="margin-bottom: 1.5rem; box-shadow: none;">
        <div style="font-weight: 800; font-size: 1.05rem; color: #2D2D2D;">Invite Friends</div>
        <div style="font-size: 0.8rem; color: #888; margin-bottom: 1rem;">Add names and what each person should bring (optional).</div>

        <div id="friendsContainer" class="d-flex flex-column gap-3"></div>

        <button type="button" onclick="addFriend()"
                style="background: none; border: none; color: var(--purple); font-weight: 800; font-size: 0.9rem; padding: 0; margin-top: 1rem; cursor: pointer;">
            + Add a Friend
        </button>
    </div>

    <button type="submit" class="btn-step">
        Create Event
    </button>

</form>

<script>
    var friendColors = ['#FFE68C', '#FFB5C6', '#B8EDD8', '#C9B8F5'];

    function reindexFriends() {
        var container = document.getElementById('friendsContainer');
        var rows = container.querySelectorAll('.friend-row');
        rows.forEach(function(row, i) {
            var badge = row.querySelector('.friend-badge');
            badge.textContent = i + 1;
            badge.style.background = friendColors[i % friendColors.length];

            var inputs = row.querySelectorAll('input');
            inputs[0].name = 'Friends[' + i + '].Name';
            inputs[0].placeholder = 'Friend ' + (i + 1) + ' name';
            inputs[1].name = 'Friends[' + i + '].Contribution';
        });
    }

    function removeFriend(btn) {
        btn.closest('.friend-row').remove();
        reindexFriends();
    }

    function addFriend() {
        var container = document.getElementById('friendsContainer');
        var index = container.querySelectorAll('.friend-row').length;
        var color = friendColors[index % friendColors.length];

        var row = document.createElement('div');
        row.className = 'friend-row d-flex align-items-start gap-2';
        row.innerHTML =
            '<div class="friend-badge avatar-circle lg" style="background: ' + color + ';">' +
                (index + 1) +
            '</div>' +
            '<div style="flex: 1;">' +
                '<input name="Friends[' + index + '].Name" class="form-control hatian-input mb-2" placeholder="Friend ' + (index + 1) + ' name" required />' +
                '<input name="Friends[' + index + '].Contribution" class="form-control hatian-input" placeholder="What they bring" required/>' +
            '</div>' +
            '<button type="button" onclick="removeFriend(this)" class="btn-remove-friend" title="Remove">✕</button>';

        container.appendChild(row);
    }
</script>