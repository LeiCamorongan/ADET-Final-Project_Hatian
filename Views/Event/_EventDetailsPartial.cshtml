@model Hatian.Models.ViewModels.EventDetailViewModel
@using Hatian.Models.Entities
@{
    var ev = Model.Event;
    var paidCount = Model.Participants.Count(p => p.IsPaid && !p.IsOrganizer);
    var totalGuests = Model.Participants.Count(p => !p.IsOrganizer);
    var progress = totalGuests == 0 ? 0 : (int)((double)paidCount / totalGuests * 100);
    string[] avatarColors = { "#FFB5C6", "#FFE68C", "#B8EDD8", "#C9B8F5" };

    // Build debts with composite key: debtorId_creditorId
    // This allows one person to owe multiple different people
    var debts = new Dictionary<string, (Guid DebtorId, string DebtorName, Guid CreditorId, string CreditorName, decimal Amount)>();
    foreach (var exp in Model.Expenses)
    {
        if (exp.Splits == null || !exp.Splits.Any()) continue;
        var splitAmount = exp.Amount / exp.Splits.Count;
        foreach (var split in exp.Splits)
        {
            if (split.ParticipantId == exp.PaidByParticipantId) continue;
            var key = $"{split.ParticipantId}_{exp.PaidByParticipantId}";
            var debtorName = split.Participant?.Name
                ?? Model.Participants.FirstOrDefault(p => p.Id == split.ParticipantId)?.Name
                ?? "?";
            var creditorName = exp.PaidBy?.Name ?? "?";
            if (debts.ContainsKey(key))
                debts[key] = (split.ParticipantId, debtorName, exp.PaidByParticipantId, creditorName, debts[key].Amount + splitAmount);
            else
                debts[key] = (split.ParticipantId, debtorName, exp.PaidByParticipantId, creditorName, splitAmount);
        }
    }

    // Net out opposing debts: if A owes B ₱333 and B owes A ₱216, show only A owes B ₱117
    var nettedDebts = new Dictionary<string, (Guid DebtorId, string DebtorName, Guid CreditorId, string CreditorName, decimal Amount)>();
    var processedPairs = new HashSet<string>();

    foreach (var kv in debts)
    {
        if (processedPairs.Contains(kv.Key)) continue;

        var debt = kv.Value;
        var reverseKey = $"{debt.CreditorId}_{debt.DebtorId}";
        decimal forward = debt.Amount;
        decimal reverse = debts.ContainsKey(reverseKey) ? debts[reverseKey].Amount : 0m;
        decimal net = forward - reverse;

        processedPairs.Add(kv.Key);
        processedPairs.Add(reverseKey);

        if (net > 0.01m)
            nettedDebts[kv.Key] = (debt.DebtorId, debt.DebtorName, debt.CreditorId, debt.CreditorName, Math.Round(net, 2));
        else if (net < -0.01m)
        {
            var rev = debts.ContainsKey(reverseKey) ? debts[reverseKey] : debt;
            nettedDebts[reverseKey] = (debt.CreditorId, debt.CreditorName, debt.DebtorId, debt.DebtorName, Math.Round(Math.Abs(net), 2));
        }
    }

    debts = nettedDebts;

    // Parse paid debt keys
    var paidDebtKeys = new HashSet<string>(
        string.IsNullOrWhiteSpace(ev.PaidDebtKeys)
            ? Array.Empty<string>()
            : ev.PaidDebtKeys.Split(',', StringSplitOptions.RemoveEmptyEntries));

    var totalDebtsCount = debts.Count;
    var paidDebtsCount = debts.Count(kv => paidDebtKeys.Contains(kv.Key));
    progress = totalDebtsCount == 0 ? 0 : (int)((double)paidDebtsCount / totalDebtsCount * 100);

    // 👇 ADDED: Overriding the UI status text if all debts are settled
    // If there are valid debt relationships AND every single one of them is marked paid:
    string eventStatusDisplay = ev.Status;
    if (totalDebtsCount > 0 && paidDebtsCount == totalDebtsCount)
    {
        eventStatusDisplay = "Complete";
    }
}


@Html.AntiForgeryToken()

<div id="eventDetailWrapper" data-event-id="@ev.Id">

    <!-- Header -->
    <div class="event-header-card">
        <div class="section-label">Event</div>
        <div class="d-flex justify-content-between align-items-start">
            <div style="font-size: 1.6rem; font-weight: 900; color: #2D2D2D;">@ev.Title</div>

            <span class="pill-badge" style="background: white; color: #2D2D2D;">@eventStatusDisplay</span>
        </div>
        <div style="font-size: 0.85rem; color: #444; margin-top: 0.5rem;">
            📅 @ev.Date.ToString("MMMM dd, yyyy") · 👥 @Model.Participants.Count people
        </div>
    </div>

    <!-- Tabs -->
    <div class="d-flex gap-2" style="margin-bottom: 1.25rem;">
        <button class="detail-tab-btn tab-btn active" data-tab="info">Info</button>
        <button class="detail-tab-btn tab-btn" data-tab="expenses">Expenses</button>
        <button class="detail-tab-btn tab-btn" data-tab="contributions">Contributions</button>
    </div>

    <!-- INFO TAB -->
    <div class="detail-tab-panel" data-tab="info">

        <div class="info-card" style="margin-bottom: 1rem;">
            <div class="section-label" style="margin-bottom: 0.5rem;">Invite Code</div>
            <div class="d-flex justify-content-between align-items-center">
                <div class="invite-code">@ev.InviteToken</div>
                <button class="copy-invite-btn btn-copy" data-code="@ev.InviteToken">
                    Copy
                </button>
            </div>
            <div style="font-size: 0.8rem; color: #888; margin-top: 0.75rem;">Share this code with your friends to let them join.</div>
        </div>

        @if (!string.IsNullOrWhiteSpace(ev.Description))
        {
            <div class="info-card" style="margin-bottom: 1rem;">
                <div class="section-label" style="margin-bottom: 0.5rem;">About This Event</div>
                <div style="font-size: 0.95rem; color: #2D2D2D;">@ev.Description</div>
            </div>
        }

        <div class="info-card">
            <div class="d-flex justify-content-between align-items-center" style="margin-bottom: 0.75rem;">
                <div class="section-label">Who's Bringing What</div>
                <button onclick="openAddMemberModal('@ev.Id')"
                        style="background: var(--green); border: var(--border); border-radius: 999px; padding: 4px 14px; font-weight: 800; font-size: 0.8rem; cursor: pointer;">
                    + Add
                </button>
            </div>
            <div class="d-flex flex-column gap-3">
                @for (int i = 0; i < Model.Participants.Count; i++)
                {
                    var p = Model.Participants[i];
                    var initial = p.Name.Length > 0 ? p.Name.Substring(0, 1).ToUpper() : "?";
                    var color = avatarColors[i % avatarColors.Length];
                    <div class="d-flex align-items-center gap-2">
                        <div class="avatar-circle lg" style="background:@color;">@initial</div>
                        <div style="flex:1;">
                            <div style="font-weight:800; color:#2D2D2D; font-size:0.95rem;">
                                @p.Name @(p.IsOrganizer ? "(you)" : "")
                            </div>
                            <div style="font-size:0.8rem; color:#888;">
                                @(string.IsNullOrWhiteSpace(p.Contribution) ? "—" : p.Contribution)
                            </div>
                        </div>
                        <button class="btn-circle-sm edit-member-btn" style="background: var(--yellow); flex-shrink:0;"
                                title="Edit member"
                                data-participant-id="@p.Id"
                                data-event-id="@ev.Id"
                                data-name="@p.Name"
                                data-contribution="@(p.Contribution ?? "")">
                            ✏️
                        </button>
                        @if (!p.IsOrganizer)
                        {
                            <button onclick="openRemoveMemberModal('@p.Id', '@ev.Id', '@p.Name')"
                                    class="btn-circle-sm" style="background: var(--pink); flex-shrink:0;"
                                    title="Remove member">
                                ✕
                            </button>
                        }
                    </div>
                }
            </div>
        </div>

    </div>

    <!-- CONTRIBUTIONS TAB -->
    <div class="detail-tab-panel" data-tab="contributions" style="display:none;">

        <!-- Payment Progress -->
        <div class="info-card" style="margin-bottom: 1rem;">
            <div class="d-flex justify-content-between align-items-center" style="margin-bottom: 0.75rem;">
                <div style="font-weight:800; font-size:1rem; color:#2D2D2D;">Payment Progress</div>

                <div style="font-size:0.85rem; color:#888; font-weight:700;">@paidDebtsCount/@totalDebtsCount paid</div>
            </div>
            <div class="progress-track">
                <div class="progress-fill" style="width:@(progress)%;"></div>
            </div>
        </div>

        @if (debts.Any())
        {
            <div class="info-card" style="margin-bottom: 1rem;">
                <div class="section-label" style="margin-bottom: 0.75rem;">Who Owes Who</div>
                <div class="d-flex flex-column gap-2">
                    @foreach (var kv in debts)
                    {
                        var debt = kv.Value;
                        var debtorIdx = Model.Participants.FindIndex(p => p.Id == debt.DebtorId);
                        var debtorInitial = debt.DebtorName.Length > 0 ? debt.DebtorName.Substring(0, 1).ToUpper() : "?";
                        var debtorColor = debtorIdx >= 0 ? avatarColors[debtorIdx % avatarColors.Length] : "#EEE";
                        var debtKey = $"{debt.DebtorId}_{debt.CreditorId}";
                        var isDebtPaid = paidDebtKeys.Contains(debtKey);
                        <div class="debt-row @(isDebtPaid ? "debt-paid" : "")"
                             onclick="toggleDebtPaid('@ev.Id', '@debt.DebtorId', '@debt.CreditorId')"
                             title="Click to mark as @(isDebtPaid ? "unpaid" : "paid")">
                            <div class="avatar-circle md" style="background:@debtorColor;">@debtorInitial</div>
                            <div style="flex:1; font-size:0.9rem; color:#2D2D2D;">
                                <span style="font-weight:800;">@debt.DebtorName</span> owes <span style="font-weight:800;">@debt.CreditorName</span>
                            </div>
                            <div style="font-weight:900; font-size:0.95rem;">
                                @if (isDebtPaid)
                                {
                                    <span style="color:#B8EDD8; font-weight:800;">Paid ✓</span>
                                }
                                else
                                {
                                    <span style="color:#2D2D2D;">₱@debt.Amount.ToString("0.00")</span>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

    

    </div>

    <!-- EXPENSES TAB -->
    <div class="detail-tab-panel" data-tab="expenses" style="display:none;">

        <button class="add-expense-toggle btn-dark-pill" style="margin-bottom:1rem;">
            + Add Expense
        </button>

        <div id="expenseForm" style="display:none; margin-bottom:1rem;">
            <div class="info-card">
                <form class="ajax-form" method="post" asp-controller="Event" asp-action="AddExpense">
                    <input type="hidden" name="NewExpense.EventId" value="@ev.Id" />
                    <div class="mb-2">
                        <label class="form-label fw-bold">Description</label>
                        <input name="NewExpense.Description" class="form-control hatian-input" placeholder="e.g. Dinner" required />
                    </div>
                    <div class="mb-2">
                        <label class="form-label fw-bold">Amount</label>
                        <input name="NewExpense.Amount" type="number" step="0.01" class="form-control hatian-input" placeholder="0.00" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Paid By</label>
                        <select name="NewExpense.PaidByParticipantId" class="form-control hatian-input">
                            @foreach (var p in Model.Participants)
                            {
                                <option value="@p.Id">@p.Name</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Split Among</label>
                        <div class="split-list">
                            @for (int i = 0; i < Model.Participants.Count; i++)
                            {
                                var p = Model.Participants[i];
                                var color = avatarColors[i % avatarColors.Length];
                                var initial = p.Name.Length > 0 ? p.Name.Substring(0, 1).ToUpper() : "?";
                                <label>
                                    <input type="checkbox" name="NewExpense.SplitAmongParticipantIds" value="@p.Id" checked />
                                    <div class="avatar-circle sm" style="background:@color;">@initial</div>
                                    <span style="font-weight:700; color:#2D2D2D; font-size:0.9rem;">@p.Name</span>
                                </label>
                            }
                        </div>
                    </div>
                    <button type="submit" class="btn-step">Save Expense</button>
                </form>
            </div>
        </div>

        @if (!Model.Expenses.Any())
        {
            <div class="info-card" style="padding:2.5rem 1.5rem; text-align:center;">
                <div style="font-size:2rem; margin-bottom:0.5rem;">🧾</div>
                <div style="font-weight:800; color:#2D2D2D; font-size:0.95rem;">No expenses yet</div>
                <div style="font-size:0.8rem; color:#888;">Add the first one above.</div>
            </div>
        }
        else
        {
            <div class="d-flex flex-column gap-2">
                @foreach (var exp in Model.Expenses)
                {
                    var splitCount = exp.Splits?.Count ?? 1;
                    var perPerson = splitCount > 0 ? exp.Amount / splitCount : exp.Amount;
                    var splitIds = string.Join(",", exp.Splits != null ? exp.Splits.Select(s => s.ParticipantId.ToString()) : Enumerable.Empty<string>());
                    <div class="info-card">
                        <div class="d-flex justify-content-between align-items-start" style="margin-bottom:0.5rem;">
                            <div style="flex:1;">
                                <div style="font-weight:800; color:#2D2D2D; font-size:0.95rem;">@exp.Description</div>
                                <div style="font-size:0.8rem; color:#888;">Paid by @exp.PaidBy?.Name · @splitCount people</div>
                            </div>
                            <div class="d-flex align-items-start gap-2">
                                <div style="text-align:right;">
                                    <div style="font-weight:900; color:#2D2D2D; font-size:1rem;">₱@exp.Amount.ToString("0.00")</div>
                                    <div style="font-size:0.75rem; color:#888;">₱@perPerson.ToString("0.00")/ea</div>
                                </div>
                                <button onclick="openEditExpenseModal('@exp.Id', '@exp.Description', @exp.Amount, '@exp.PaidByParticipantId', '@splitIds')"
                                        class="btn-circle-sm" style="background: var(--yellow);">
                                    ✏️
                                </button>
                                <button onclick="openDeleteExpenseModal('@exp.Id', '@ev.Id')"
                                        class="btn-circle-sm" style="background: var(--pink);">
                                    🗑
                                </button>
                            </div>
                        </div>
                        @if (exp.Splits != null && exp.Splits.Any())
                        {
                            <div class="d-flex gap-1 flex-wrap">
                                @foreach (var split in exp.Splits)
                                {
                                    var idx = Model.Participants.FindIndex(p => p.Id == split.ParticipantId);
                                    var sc = idx >= 0 ? avatarColors[idx % avatarColors.Length] : "#EEE";
                                    var si = idx >= 0 && Model.Participants[idx].Name.Length > 0
                                        ? Model.Participants[idx].Name.Substring(0, 1).ToUpper() : "?";
                                    <div class="avatar-circle sm" style="background:@sc;">@si</div>
                                }
                            </div>
                        }
                    </div>
                }
            </div>
        }

    </div>

</div>

<!-- Edit Expense Modal -->
<div id="editExpenseModal" class="modal-overlay">
    <form class="modal-box wide ajax-form" method="post" asp-controller="Event" asp-action="EditExpense">
        <input type="hidden" id="editExpenseId" name="expenseId" />
        <div style="font-size:1.2rem; font-weight:900; color:#2D2D2D; margin-bottom:1.5rem; text-align:center;">Edit Expense</div>
        <div class="mb-3">
            <label class="form-label fw-bold">Description</label>
            <input id="editExpenseDescription" name="description" class="form-control hatian-input" required />
        </div>
        <div class="mb-3">
            <label class="form-label fw-bold">Amount</label>
            <input id="editExpenseAmount" name="amount" type="number" step="0.01" class="form-control hatian-input" required />
        </div>
        <div class="mb-3">
            <label class="form-label fw-bold">Paid By</label>
            <select id="editExpensePaidBy" name="paidByParticipantId" class="form-control hatian-input">
                @foreach (var p in Model.Participants)
                {
                    <option value="@p.Id">@p.Name</option>
                }
            </select>
        </div>
        <div class="mb-4">
            <label class="form-label fw-bold">Split Among</label>
            <div class="split-list">
                @for (int i = 0; i < Model.Participants.Count; i++)
                {
                    var p = Model.Participants[i];
                    var color = avatarColors[i % avatarColors.Length];
                    var initial = p.Name.Length > 0 ? p.Name.Substring(0, 1).ToUpper() : "?";
                    <label>
                        <input type="checkbox" class="edit-split-checkbox" name="splitParticipantIds" value="@p.Id" />
                        <div class="avatar-circle sm" style="background:@color;">@initial</div>
                        <span style="font-weight:700; color:#2D2D2D; font-size:0.9rem;">@p.Name</span>
                    </label>
                }
            </div>
        </div>
        <div class="d-flex gap-2 justify-content-end">
            <button type="button" onclick="closeEditExpenseModal()" class="btn-modal light">Cancel</button>
            <button id="confirmEditExpenseBtn" type="submit" class="btn-modal dark">Save Changes</button>
        </div>
    </form>
</div>

<!-- Add Member Modal -->
<div id="addMemberModal" class="modal-overlay">
    <form class="modal-box wide ajax-form" style="max-width:400px;" method="post" asp-controller="Event" asp-action="AddMember">
        <input type="hidden" name="eventId" value="@ev.Id" />
        <div style="font-size:1.2rem; font-weight:900; color:#2D2D2D; margin-bottom:1.5rem; text-align:center;">Add Member</div>
        <div class="mb-3">
            <label class="form-label fw-bold">Name</label>
            <input id="newMemberName" name="name" class="form-control hatian-input" placeholder="e.g. Jungkook" required />
        </div>
        <div class="mb-4">
            <label class="form-label fw-bold">Contribution</label>
            <input id="newMemberContribution" name="contribution" class="form-control hatian-input" placeholder="e.g. Snacks (optional)" />
        </div>
        <div class="d-flex gap-3 justify-content-center">
            <button type="button" onclick="closeAddMemberModal()" class="btn-modal light">Cancel</button>
            <button type="submit" class="btn-modal dark">Add Member</button>
        </div>
    </form>
</div>

<!-- Delete Expense Modal -->
<div id="deleteExpenseModal" class="modal-overlay">
    <div class="modal-box">
        <div style="font-size:1.2rem; font-weight:900; color:#2D2D2D; margin-bottom:0.5rem;">Delete this expense?</div>
        <div style="font-size:0.9rem; color:#555; margin-bottom:1.5rem;">This cannot be undone.</div>
        <div class="d-flex gap-3 justify-content-center">
            <button onclick="closeDeleteExpenseModal()" class="btn-modal light">Cancel</button>
            <button id="confirmDeleteExpenseBtn" type="button" class="btn-modal dark">Yes, Delete</button>
        </div>
    </div>
</div>

<!-- Remove Member Modal -->
<div id="removeMemberModal" class="modal-overlay">
    <div class="modal-box">
        <div style="font-size:1.2rem; font-weight:900; color:#2D2D2D; margin-bottom:0.5rem;">Remove this member?</div>
        <div id="removeMemberMessage" style="font-size:0.9rem; color:#555; margin-bottom:1.5rem;">This will also remove their expenses and splits.</div>
        <div class="d-flex gap-3 justify-content-center">
            <button onclick="closeRemoveMemberModal()" class="btn-modal light">Cancel</button>
            <button id="confirmRemoveMemberBtn" type="button" class="btn-modal dark">Yes, Remove</button>
        </div>
    </div>
</div>

<!-- Edit Member Modal -->
<div id="editMemberModal" class="modal-overlay">
    <form class="modal-box wide ajax-form" style="max-width:400px;" method="post" asp-controller="Event" asp-action="EditMember">
        <input type="hidden" id="editMemberParticipantId" name="participantId" />
        <input type="hidden" id="editMemberEventId" name="eventId" />
        <div style="font-size:1.2rem; font-weight:900; color:#2D2D2D; margin-bottom:1.5rem; text-align:center;">Edit Member</div>
        <div class="mb-3">
            <label class="form-label fw-bold">Name</label>
            <input id="editMemberName" name="name" class="form-control hatian-input" required />
        </div>
        <div class="mb-4">
            <label class="form-label fw-bold">Contribution</label>
            <input id="editMemberContribution" name="contribution" class="form-control hatian-input" placeholder="e.g. Snacks (optional)" />
        </div>
        <div class="d-flex gap-3 justify-content-center">
            <button type="button" onclick="closeEditMemberModal()" class="btn-modal light">Cancel</button>
            <button type="submit" class="btn-modal dark">Save Changes</button>
        </div>
    </form>
</div>
