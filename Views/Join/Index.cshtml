@model Hatian.Models.ViewModels.JoinEventViewModel

@{
    ViewData["Title"] = "Join Event";
}

<div class="container py-5">
    <div style="max-width:500px; margin: 0 auto;">

        <div class="mb-3">
            <a asp-controller="Home" asp-action="Index" class="btn-back">
                ← Back to Home
            </a>
        </div>

        <div class="hatian-card">
            <h2 class="fw-bold mb-4">Join Event</h2>

            <form asp-action="Index" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
                <input asp-for="InviteToken"
                       class="form-control hatian-input mb-3"
                       placeholder="Enter Invite Code" required />
                <button class="btn btn-dark rounded-pill w-100">Continue</button>
            </form>
        </div>

    </div>
</div>