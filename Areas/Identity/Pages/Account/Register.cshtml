@page
@model RegisterModel
@{
    ViewData["Title"] = "Create Account";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-5">

            <!-- Back to Home Button -->
            <div class="mb-3">
                <a asp-controller="Home" asp-action="Index"
                   style="display: inline-flex; align-items: center; gap: 6px; background: white; border: 2px solid #2D2D2D; border-radius: 999px; padding: 8px 20px; font-weight: 800; font-size: 0.9rem; box-shadow: 3px 3px 0px #2D2D2D; text-decoration: none; color: #2D2D2D;">
                    ← Back to Home
                </a>
            </div>

            <div class="hatian-card">
                <div class="text-center mb-4">
                    <img src="~/images/HatianLogo.png" alt="Hatian" style="height:120px;" />
                    <h2 class="fw-bold mt-3">Join the Barkada 🎉</h2>
                    <p class="text-muted">Create your Hatian account and start splitting expenses stress-free.</p>
                </div>

                <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Input.Email" class="form-label fw-bold">Email Address</label>
                        <input asp-for="Input.Email" class="form-control hatian-input" placeholder="juan@email.com" />
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.Password" class="form-label fw-bold">Password</label>
                        <input asp-for="Input.Password" class="form-control hatian-input" placeholder="Enter password" />
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Input.ConfirmPassword" class="form-label fw-bold">Confirm Password</label>
                        <input asp-for="Input.ConfirmPassword" class="form-control hatian-input" placeholder="Confirm password" />
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                    </div>

                    <button id="registerSubmit" type="submit" class="btn-step">Create Account</button>

                    <div class="text-center mt-4">
                        <a asp-page="./Login" class="text-decoration-none fw-bold">Already have an account? Log In</a>
                    </div>
                </form>
            </div>

        </div>
    </div>
</div>

@if (TempData["RegisterSuccess"] != null)
{
    <!-- Success Modal -->
    <div class="modal fade" id="successModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content rounded-4 border-0 shadow">
                <div class="modal-body text-center p-5">
                    <div class="mb-3" style="font-size: 3rem;">🎉</div>
                    <h4 class="fw-bold">Account Created!</h4>
                    <p class="text-muted">You can now log in using your credentials.</p>
                    <a asp-page="./Login" class="btn-step d-inline-block mt-2">Go to Login</a>
                </div>
            </div>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var modal = new bootstrap.Modal(document.getElementById('successModal'), {
                backdrop: 'static',
                keyboard: false
            });
            modal.show();
        });
    </script>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}