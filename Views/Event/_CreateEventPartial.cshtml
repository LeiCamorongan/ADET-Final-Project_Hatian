@model Hatian.Models.ViewModels.CreateEventViewModel

<h2 class="fw-bold mb-4">Create Event</h2>

<form asp-controller="Event" asp-action="Create" method="post">

    <div class="mb-3">
        <label class="form-label fw-bold">Event Title</label>
        <input asp-for="Title" class="form-control hatian-input" />
    </div>

    <div class="mb-3">
        <label class="form-label fw-bold">Description</label>
        <textarea asp-for="Description" class="form-control hatian-input"></textarea>
    </div>

    <div class="mb-4">
        <label class="form-label fw-bold">Date</label>
        <input asp-for="Date" type="date" class="form-control hatian-input" />
    </div>

    <!-- Your Contribution -->
    <div style="background: white; border: 2px solid #2D2D2D; border-radius: 16px; padding: 1.25rem; margin-bottom: 1rem;">
        <div style="font-weight: 800; font-size: 1.05rem; color: #2D2D2D;">Your Contribution</div>
        <div style="font-size: 0.8rem; color: #888; margin-bottom: 1rem;">What are you bringing to this event?</div>

        <div style="display: flex; align-items: center; gap: 12px;">
            <div style="width: 40px; height: 40px; flex-shrink: 0; border-radius: 50%; background: #FFB5C6; color: #2D2D2D; display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 0.85rem; border: 2px solid #2D2D2D;">
                YOU
            </div>
            <div style="flex: 1;">
                <input asp-for="OrganizerNameAsParticipant"
                       class="form-control hatian-input mb-2"
                       placeholder="Your Name" />
                <input asp-for="OrganizerContribution"
                       class="form-control hatian-input"
                       placeholder="e.g. desserts, drinks, plates..." />
            </div>
        </div>
    </div>

    <!-- Invite Friends -->
    <div style="background: white; border: 2px solid #2D2D2D; border-radius: 16px; padding: 1.25rem; margin-bottom: 1.5rem;">
        <div style="font-weight: 800; font-size: 1.05rem; color: #2D2D2D;">Invite Friends</div>
        <div style="font-size: 0.8rem; color: #888; margin-bottom: 1rem;">Add names and what each person should bring (optional).</div>

        <div id="friendsContainer" class="d-flex flex-column gap-3">
            <div class="friend-row d-flex align-items-start gap-2">
                <div style="width: 40px; height: 40px; flex-shrink: 0; border-radius: 50%; background: #FFE68C; color: #2D2D2D; display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 0.95rem; border: 2px solid #2D2D2D;">
                    1
                </div>
                <div style="flex: 1;">
                    <input name="Friends[0].Name" class="form-control hatian-input mb-2" placeholder="Friend 1 name" />
                    <input name="Friends[0].Contribution" class="form-control hatian-input" placeholder="What they bring (optional)" />
                </div>
            </div>
        </div>

        <button type="button" onclick="addFriend()"
                style="background: none; border: none; color: #C9B8F5; font-weight: 800; font-size: 0.9rem; padding: 0; margin-top: 1rem; cursor: pointer;">
            + Add Another Friend
        </button>
    </div>

    <button type="submit" class="btn rounded-pill w-100 fw-bold"
            style="background: #2D2D2D; color: white; border: 2px solid #2D2D2D; padding: 0.8rem; box-shadow: 4px 4px 0px #C9B8F5;">
        Create Event
    </button>

</form>

<script>
    let friendCount = 1;

    function addFriend() {
        const container = document.getElementById('friendsContainer');
        const index = friendCount;

        const colors = ['#FFB5C6', '#FFE68C', '#B8EDD8', '#C9B8F5'];
        const color = colors[index % colors.length];

        const row = document.createElement('div');
        row.className = 'friend-row d-flex align-items-start gap-2';
        row.innerHTML = `
            <div style="width: 40px; height: 40px; flex-shrink: 0; border-radius: 50%; background: ${color}; color: #2D2D2D; display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 0.95rem; border: 2px solid #2D2D2D;">
                ${index + 1}
            </div>
            <div style="flex: 1;">
                <input name="Friends[${index}].Name" class="form-control hatian-input mb-2" placeholder="Friend ${index + 1} name" />
                <input name="Friends[${index}].Contribution" class="form-control hatian-input" placeholder="What they bring (optional)" />
            </div>
        `;

        container.appendChild(row);
        friendCount++;
    }
</script>