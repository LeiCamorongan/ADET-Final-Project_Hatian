@model Hatian.Models.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<!-- Delete Event Modal -->
<div id="deleteModal" class="modal-overlay">
    <div class="modal-box">
        <div style="font-size:1.2rem; font-weight:900; color:#2D2D2D; margin-bottom:0.5rem;">Delete this event?</div>
        <div style="font-size:0.9rem; color:#555; margin-bottom:1.5rem;">This cannot be undone. All participants and expenses will be removed.</div>
        <div class="d-flex gap-3 justify-content-center">
            <button onclick="closeDeleteModal()" class="btn-modal light">Cancel</button>
            <form id="deleteForm" method="post" asp-controller="Event" asp-action="Delete">
                <input type="hidden" name="id" id="deleteEventId" />
                <button type="submit" class="btn-modal dark">Yes, Delete</button>
            </form>
        </div>
    </div>
</div>

<!-- Create Event Panel -->
<div id="createOverlay" onclick="closeCreatePanel()" class="side-overlay"></div>
<div id="createPanel" class="side-panel" style="right:-450px; width:420px; max-width:90vw;">
    <button onclick="closeCreatePanel()" class="panel-close-btn">✕</button>
    @await Html.PartialAsync("~/Views/Event/_CreateEventPartial.cshtml", new Hatian.Models.ViewModels.CreateEventViewModel())
</div>

<!-- Event Details Panel -->
<div id="detailsOverlay" onclick="closeDetailsPanel()" class="side-overlay"></div>
<div id="detailsPanel" class="side-panel" style="right:-520px; width:480px; max-width:90vw; background: var(--bg-light);">
    <button onclick="closeDetailsPanel()" class="panel-close-btn">✕</button>
    <div id="detailsPanelContent"></div>
</div>

<div class="dashboard-wrapper">
    <div class="dashboard-container">
        <div class="d-flex align-items-start" style="gap: 3rem;">

            <!-- LEFT: profile card -->
            <div class="profile-sidebar">
                <div class="profile-avatar-wrapper">
                    <img src="https://api.dicebear.com/7.x/adventurer/svg?seed=@User.Identity!.Name&backgroundColor=ffffff"
                         alt="Avatar" style="width: 100%; height: auto; display: block;" />
                </div>
                <div style="padding: 1rem 0.25rem 0;">
                    <div class="profile-name">Welcome Back!</div>
                    <div class="profile-email">@User.Identity!.Name</div>
                </div>
            </div>

            <!-- RIGHT: main content -->
            <div class="dashboard-content">

                <!-- Stats -->
                <div class="d-flex gap-3">
                    <div class="stat-box" style="background: var(--pink);">
                        <div class="stat-title">Active Events</div>
                        <div class="stat-value">@Model.ActiveEvents.Count</div>
                    </div>
                    <div class="stat-box" style="background: var(--green);">
                        <div class="stat-title">Completed</div>
                        <div class="stat-value">@Model.CompletedEvents.Count</div>
                    </div>
                </div>

                <!-- New Event -->
                <div onclick="openCreatePanel()" class="new-event-card d-flex align-items-center gap-3">
                    <div class="icon-circle">+</div>
                    <div>
                        <div style="font-weight: 800; color: #2D2D2D; font-size: 1rem;">New Event</div>
                        <div style="font-size: 0.8rem; color: #555; font-weight: 500;">Create and invite friends</div>
                    </div>
                </div>

                <!-- Active Events -->
                <div>
                    <span class="step-label mb-2 d-inline-block">Active</span>
                    <div class="d-flex flex-column gap-2">
                        @if (!Model.ActiveEvents.Any())
                        {
                            <div class="info-card" style="text-align: center; font-size: 0.9rem; font-weight: 600;">
                                No active events yet. Create one above!
                            </div>
                        }
                        else
                        {
                            @foreach (var ev in Model.ActiveEvents)
                            {
                                var paidCount = ev.Participants.Count(p => p.IsPaid && !p.IsOrganizer);
                                var totalGuests = ev.Participants.Count(p => !p.IsOrganizer);

                                <div data-event-card="@ev.Id" class="event-card" style="background: var(--pink);">
                                    <a href="#" onclick="openDetailsPanel('@ev.Id'); return false;" class="text-decoration-none" style="flex: 1;">
                                        <div class="event-title">@ev.Title</div>
                                        <div class="event-meta">
                                            📅 @ev.Date.ToString("MMM dd, yyyy") · 👥 @ev.Participants.Count person@(ev.Participants.Count != 1 ? "s" : "")
                                        </div>
                                    </a>
                                    <div class="d-flex align-items-center gap-2" style="flex-shrink: 0;">
                                        <span class="pill-badge paid-badge" style="background: var(--yellow); color: #2D2D2D;">
                                            ⏱ @paidCount/@totalGuests paid
                                        </span>
                                        <button onclick="openDeleteModal('@ev.Id')" class="pill-badge" style="background: #2D2D2D; color: white; cursor: pointer;">
                                            🗑 Delete
                                        </button>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>

                <!-- Completed Events -->
                <div>
                    <span class="step-label mb-2 d-inline-block">Completed</span>
                    <div class="d-flex flex-column gap-2">
                        @if (!Model.CompletedEvents.Any())
                        {
                            <div class="info-card" style="text-align: center; font-size: 0.9rem; font-weight: 600;">
                                No completed events yet.
                            </div>
                        }
                        else
                        {
                            @foreach (var ev in Model.CompletedEvents)
                            {
                                <div class="event-card" style="background: var(--green);">
                                    <a href="#" onclick="openDetailsPanel('@ev.Id'); return false;" class="text-decoration-none" style="flex: 1;">
                                        <div class="event-title">@ev.Title</div>
                                        <div class="event-meta">
                                            📅 @ev.Date.ToString("MMM dd, yyyy") · 👥 @ev.Participants.Count person@(ev.Participants.Count != 1 ? "s" : "")
                                        </div>
                                    </a>
                                    <div class="d-flex align-items-center gap-2" style="flex-shrink: 0;">
                                        <span class="pill-badge" style="background: var(--purple); color: #2D2D2D;">
                                            Done
                                        </span>
                                        <button onclick="openDeleteModal('@ev.Id')" class="pill-badge" style="background: #2D2D2D; color: white; cursor: pointer;">
                                            🗑 Delete
                                        </button>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // modal helpers
        function openDeleteModal(eventId) {
            document.getElementById('deleteEventId').value = eventId;
            document.getElementById('deleteModal').style.display = 'flex';
        }
        function closeDeleteModal() {
            document.getElementById('deleteModal').style.display = 'none';
        }

        // create panel
        function openCreatePanel() {
            document.getElementById('createOverlay').style.display = 'block';
            document.getElementById('createPanel').style.right = '0';
        }
        function closeCreatePanel() {
            document.getElementById('createOverlay').style.display = 'none';
            document.getElementById('createPanel').style.right = '-450px';
        }

        // details panel
        function openDetailsPanel(eventId) {
            fetch('/Event/DetailsPartial/' + eventId)
                .then(r => r.text())
                .then(html => {
                    document.getElementById('detailsPanelContent').innerHTML = html;
                    document.getElementById('detailsOverlay').style.display = 'block';
                    document.getElementById('detailsPanel').style.right = '0';
                    initDetailsPanel();
                });
        }
        function closeDetailsPanel() {
            document.getElementById('detailsOverlay').style.display = 'none';
            document.getElementById('detailsPanel').style.right = '-520px';
        }

        // set up tab switching and ajax forms inside the details panel
        function initDetailsPanel() {
            var content = document.getElementById('detailsPanelContent');
            var wrapper = content.querySelector('#eventDetailWrapper');
            if (!wrapper) return;
            var eventId = wrapper.dataset.eventId;

            // tabs
            content.querySelectorAll('.detail-tab-btn').forEach(function(btn) {
                btn.addEventListener('click', function() {
                    var target = btn.dataset.tab;
                    content.querySelectorAll('.detail-tab-btn').forEach(function(b) {
                        var isActive = b.dataset.tab === target;
                        b.style.background = isActive ? '#2D2D2D' : 'white';
                        b.style.color = isActive ? 'white' : '#2D2D2D';
                        if (isActive) b.classList.add('active');
                        else b.classList.remove('active');
                    });
                    content.querySelectorAll('.detail-tab-panel').forEach(function(p) {
                        p.style.display = p.dataset.tab === target ? 'block' : 'none';
                    });
                });
            });

            // expense form toggle
            var toggleBtn = content.querySelector('.add-expense-toggle');
            if (toggleBtn) {
                toggleBtn.addEventListener('click', function() {
                    var form = content.querySelector('#expenseForm');
                    form.style.display = form.style.display === 'none' ? 'block' : 'none';
                });
            }

            // copy invite code
            var copyBtn = content.querySelector('.copy-invite-btn');
            if (copyBtn) {
                copyBtn.addEventListener('click', function() {
                    navigator.clipboard.writeText(copyBtn.dataset.code).then(function() {
                        var original = copyBtn.innerHTML;
                        copyBtn.innerHTML = 'Copied!';
                        copyBtn.style.background = '#B8EDD8';
                        setTimeout(function() {
                            copyBtn.innerHTML = original;
                            copyBtn.style.background = '#FFE68C';
                        }, 2000);
                    });
                });
            }

            // ajax forms (add expense, mark paid)
            content.querySelectorAll('.ajax-form').forEach(function(form) {
                form.addEventListener('submit', function(e) {
                    e.preventDefault();
                    fetch(form.action, {
                        method: 'POST',
                        body: new FormData(form)
                    }).then(function(res) {
                        if (res.ok) refreshDetailsPanel(eventId);
                    });
                });
            });
        }

        function refreshDetailsPanel(eventId) {
            // save which tab is open before refreshing
            var activeBtn = document.querySelector('#detailsPanelContent .detail-tab-btn.active');
            var activeTab = activeBtn ? activeBtn.dataset.tab : 'info';

            fetch('/Event/DetailsPartial/' + eventId)
                .then(r => r.text())
                .then(html => {
                    document.getElementById('detailsPanelContent').innerHTML = html;
                    initDetailsPanel();

                    // restore the tab
                    var tabBtn = document.querySelector('#detailsPanelContent .detail-tab-btn[data-tab="' + activeTab + '"]');
                    if (tabBtn) tabBtn.click();

                    // also update the paid badge on the dashboard card
                    var panel = document.getElementById('detailsPanelContent');
                    var match = panel.textContent.match(/(\d+)\/(\d+) paid/);
                    if (match) {
                        var card = document.querySelector('[data-event-card="' + eventId + '"]');
                        if (card) {
                            var badge = card.querySelector('.paid-badge');
                            if (badge) badge.textContent = match[1] + '/' + match[2] + ' paid';
                        }
                    }
                });
        }

        // close modal on overlay click
        document.addEventListener('DOMContentLoaded', function() {
            var deleteModal = document.getElementById('deleteModal');
            if (deleteModal) {
                deleteModal.addEventListener('click', function(e) {
                    if (e.target === this) closeDeleteModal();
                });
            }
        });

    // details panel modal functions
    // edit expense
    function openEditExpenseModal(expenseId, description, amount, paidByParticipantId, splitIdsStr) {
        var modal = document.getElementById('editExpenseModal');
        modal.style.display = 'flex';

        document.getElementById('editExpenseId').value = expenseId;
        document.getElementById('editExpenseDescription').value = description;
        document.getElementById('editExpenseAmount').value = amount;
        document.getElementById('editExpensePaidBy').value = paidByParticipantId;

        var splitIds = splitIdsStr ? splitIdsStr.split(',') : [];
        document.querySelectorAll('.edit-split-checkbox').forEach(function(cb) {
            cb.checked = splitIds.includes(cb.value);
        });

        modal.onclick = function(e) { if (e.target === modal) closeEditExpenseModal(); };
    }

    function closeEditExpenseModal() {
        document.getElementById('editExpenseModal').style.display = 'none';
    }

    // add member
    function openAddMemberModal() {
        var modal = document.getElementById('addMemberModal');
        modal.style.display = 'flex';
        document.getElementById('newMemberName').value = '';
        document.getElementById('newMemberContribution').value = '';

        modal.onclick = function(e) { if (e.target === modal) closeAddMemberModal(); };
    }

    function closeAddMemberModal() {
        document.getElementById('addMemberModal').style.display = 'none';
        document.getElementById('newMemberName').value = '';
        document.getElementById('newMemberContribution').value = '';
    }

    // delete expense
    function openDeleteExpenseModal(expenseId, eventId) {
        var modal = document.getElementById('deleteExpenseModal');
        modal.style.display = 'flex';

        var oldBtn = document.getElementById('confirmDeleteExpenseBtn');
        var newBtn = oldBtn.cloneNode(true);
        oldBtn.parentNode.replaceChild(newBtn, oldBtn);

        newBtn.addEventListener('click', function() {
            var formData = new FormData();
            formData.append('expenseId', expenseId);
            formData.append('eventId', eventId);

            var token = document.querySelector('input[name="__RequestVerificationToken"]').value;
            formData.append('__RequestVerificationToken', token);

            fetch('/Event/DeleteExpense', { method: 'POST', body: formData })
                .then(function(res) {
                    if (res.ok) {
                        closeDeleteExpenseModal();
                        refreshDetailsPanel(eventId);
                    }
                });
        });

        modal.onclick = function(e) { if (e.target === modal) closeDeleteExpenseModal(); };
    }

    function closeDeleteExpenseModal() {
        document.getElementById('deleteExpenseModal').style.display = 'none';
    }

    // remove member
    function openRemoveMemberModal(participantId, eventId, memberName) {
        var modal = document.getElementById('removeMemberModal');
        modal.style.display = 'flex';
        document.getElementById('removeMemberMessage').textContent =
            'Remove ' + memberName + '? This will also remove their expenses and splits.';

        var oldBtn = document.getElementById('confirmRemoveMemberBtn');
        var newBtn = oldBtn.cloneNode(true);
        oldBtn.parentNode.replaceChild(newBtn, oldBtn);

        newBtn.addEventListener('click', function() {
            var formData = new FormData();
            formData.append('participantId', participantId);
            formData.append('eventId', eventId);

            var token = document.querySelector('input[name="__RequestVerificationToken"]').value;
            formData.append('__RequestVerificationToken', token);

            fetch('/Event/RemoveMember', { method: 'POST', body: formData })
                .then(function(res) {
                    if (res.ok) {
                        closeRemoveMemberModal();
                        refreshDetailsPanel(eventId);
                    }
                });
        });

        modal.onclick = function(e) { if (e.target === modal) closeRemoveMemberModal(); };
    }

    function closeRemoveMemberModal() {
        document.getElementById('removeMemberModal').style.display = 'none';
    }
    </script>
}